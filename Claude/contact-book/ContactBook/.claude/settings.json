{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath // empty' | { read -r f; case \"$f\" in *.java) mvn -q spotless:apply \"-DspotlessFiles=$f\" ;; esac; } 2>/dev/null || true",
            "statusMessage": "Formatiram Java (Spotless)..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"wow ala ovo radi dobro! :)\"}'"
          }
        ]
      }
    ]
  }
}
